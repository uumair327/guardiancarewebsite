# ==========================================
#     GuardianCare Enterprise .gitignore
# ==========================================

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build
/dist
/out
.next/

# Next.js / Serverless / Cloud
.serverless/
.firebase/
firebase-export-*

# misc
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.nyc_output

# environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*

# editor directories and files
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OSX
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Documentation configs
.vuepress/dist
.vercel

# Vercel / Netlify / Deployments
.vercel
.netlify
netlify-cli*

# Analytics / Coverage
.nyc_output
coverage/

# Cached files
.eslintcache
.stylelintcache
.prettiercache

# ==========================================
#     Security & Credentials  (CRITICAL)
# ==========================================
# Keys and Certs
*.key
*.pem
*.cer
*.crt
*.cert
*.p12
*.pfx

# GCP / Firebase Service Accounts
*-private*.json
*service-account*.json
firebase-adminsdk*.json
google-credentials.json
Firebase-keys.json

# Generic Credentials
secrets/
.secret
*.secret
secret*.json
credentials.json
auth.json
token.json
oauth.json
.htpasswd

# API Keys
api_key*
apikey*

# SSH Keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Database
*.sqlite
*.sqlite3
*.db
*.mdb
